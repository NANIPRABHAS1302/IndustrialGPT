# IndustrialGPT Environment Configuration

# Project Metadata
PROJECT_NAME="IndustrialGPT"
VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=true
API_V1_STR="/api/v1"
SECRET_KEY="industrial-gpt-super-secret-key-change-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
HOST="0.0.0.0"
PORT=8000
WORKERS_COUNT=4

# Database (PostgreSQL Async)
POSTGRES_SERVER="postgres"
POSTGRES_PORT=5432
POSTGRES_USER="industrial_admin"
POSTGRES_PASSWORD="industrial_password_2026"
POSTGRES_DB="industrial_gpt_db"
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Redis Cache & Broker
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# RabbitMQ Message Broker
RABBITMQ_HOST="rabbitmq"
RABBITMQ_PORT=5672
RABBITMQ_USER="guest"
RABBITMQ_PASSWORD="guest"
RABBITMQ_VHOST="/"

# Neo4j Knowledge Graph
NEO4J_URI="bolt://neo4j:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="industrial_neo4j_password"

# ChromaDB Vector Database
CHROMADB_HOST="chromadb"
CHROMADB_PORT=8000
CHROMADB_COLLECTION_NAME="industrial_docs"

# AI / LLM Integration
OPENAI_API_KEY="sk-placeholder-key"
OPENAI_API_BASE="https://api.openai.com/v1"
LLM_MODEL="gpt-4o"
EMBEDDING_MODEL="text-embedding-3-small"

# CORS Settings
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:5173"]
